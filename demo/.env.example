# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Google OAuth — https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Microsoft Entra ID OAuth — https://portal.azure.com/
# Authorization callback URL: http://localhost:3000/api/auth/callback/microsoft-entra-id
MICROSOFT_ENTRA_ID_ID=your_microsoft_entra_id
MICROSOFT_ENTRA_ID_SECRET=your_microsoft_entra_secret
# Issuer URL, for example: https://login.microsoftonline.com/<tenant-id>/v2.0
MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/your_tenant_id/v2.0
